rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net - default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Subscriptions collection
    match /subscriptions/{subscriptionId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
    }

    // Upload History collection
    match /upload_history/{uploadId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, delete: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
    }

    // User Profiles collection
    match /profiles/{profileId} {
      allow create, update: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
    }

    // Payments collection
    match /payments/{paymentId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
    }
  }
}
